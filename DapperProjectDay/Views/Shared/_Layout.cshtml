<!DOCTYPE html>
<html lang="en"
      class="light-style layout-menu-fixed"
      dir="ltr">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>CargoTrack Analytics Platform</title>

    <link rel="stylesheet" href="~/assets/vendor/fonts/boxicons.css" />

    <link rel="stylesheet"
          href="~/assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.css" />

    <link rel="stylesheet"
          href="~/assets/vendor/css/core.css" />

    <link rel="stylesheet"
          href="~/assets/vendor/css/theme-default.css" />

    <link rel="stylesheet"
          href="~/assets/css/demo.css" />

    <script src="~/assets/vendor/js/helpers.js"></script>

    <style>

        .layout-menu {
            background: linear-gradient( 180deg, #ffffff 0%, #f8f9ff 100%);
            box-shadow: 0 0 30px rgba(0,0,0,.06);
        }

        .app-brand {
            padding: 20px;
            border-bottom: 1px solid #eceef3;
        }

        .brand-title {
            font-size: 24px;
            font-weight: 700;
            color: #566a7f;
            line-height: 1.1;
        }

        .brand-subtitle {
            font-size: 11px;
            color: #a1acb8;
            letter-spacing: .4px;
        }

        .menu-link {
            border-radius: 14px;
            margin: 5px 12px;
            transition: .25s ease;
        }

            .menu-link:hover {
                background: #696cff !important;
                color: white !important;
                transform: translateX(4px);
            }

                .menu-link:hover i {
                    color: white !important;
                }

        .menu-item.active .menu-link {
            background: #696cff;
            color: white;
            box-shadow: 0 8px 20px rgba(105,108,255,.30);
        }

        .menu-item.active i {
            color: white;
        }

        .menu-header-text {
            font-weight: 700;
            letter-spacing: 1px;
        }

        .layout-page {
            background: #f5f5f9;
        }

    </style>

</head>

<body>

    <div class="layout-wrapper layout-content-navbar">

        <div class="layout-container">

            <!-- Sidebar -->

            <aside id="layout-menu"
                   class="layout-menu menu-vertical menu bg-menu-theme">

                <div class="app-brand">

                    <a href="/"
                       class="app-brand-link d-flex align-items-center">


                        <div class="ms-3">

                            <div class="brand-title">
                                CargoTrack
                            </div>

                            <div class="brand-subtitle">
                                Logistics Analytics Platform
                            </div>

                        </div>

                    </a>

                </div>

                <ul class="menu-inner py-3">

                    <li class="menu-header small text-uppercase">
                        <span class="menu-header-text">
                            Main Navigation
                        </span>
                    </li>

                    <li class="menu-item active">

                        <a href="/"
                           class="menu-link">

                            <i class="menu-icon tf-icons bx bx-grid-alt"></i>

                            <div>
                                Dashboard
                            </div>

                        </a>

                    </li>

                    <li class="menu-item">

                        <a href="/Shipment/Index"
                           class="menu-link">

                            <i class="menu-icon tf-icons bx bx-package"></i>

                            <div>
                                Shipments
                            </div>

                        </a>

                    </li>

                    <li class="menu-item">

                        <a href="/Courier/Index"
                           class="menu-link">

                            <i class="menu-icon tf-icons bx bx-truck"></i>

                            <div>
                                Courier Management
                            </div>

                        </a>

                    </li>

                    <li class="menu-item">

                        <a href="/Import/Index"
                           class="menu-link">

                            <i class="menu-icon tf-icons bx bx-upload"></i>

                            <div>
                                CSV Import
                            </div>

                        </a>

                    </li>

                    <li class="menu-header small text-uppercase mt-3">

                        <span class="menu-header-text">
                            Analytics
                        </span>

                    </li>

                    <li class="menu-item">

                        <a href="#"
                           class="menu-link">

                            <i class="menu-icon tf-icons bx bx-line-chart"></i>

                            <div>
                                Reports
                            </div>

                        </a>

                    </li>

                </ul>

            </aside>

            <!-- / Sidebar -->

            <div class="layout-page">

                <div class="content-wrapper">

                    <div class="container-xxl flex-grow-1 container-p-y">

                        @RenderBody()

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script src="~/assets/vendor/libs/jquery/jquery.js"></script>

    <script src="~/assets/vendor/js/bootstrap.js"></script>

    <script src="~/assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.js"></script>

    <script src="~/assets/vendor/js/menu.js"></script>

    <script src="~/assets/js/main.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>