@model List<DapperProjectDay.Models.Shipment>

<div class="card">

    <div class="card-header d-flex justify-content-between align-items-center">

        <h4 class="mb-0">
            Shipment Operations
        </h4>

        <a href="/Shipment/CreateShipment"
           class="btn btn-primary px-4">

            <i class="bx bx-plus me-1"></i>

            New Shipment

        </a>

    </div>

    <div class="card-body border-bottom">

        <form method="get">

            <div class="row">

                <div class="col-md-3">

                    <input type="text"
                           name="trackingCode"
                           class="form-control"
                           placeholder="Tracking Code" />

                </div>

                <div class="col-md-3">

                    <input type="text"
                           name="senderCity"
                           class="form-control"
                           placeholder="Sender City" />

                </div>

                <div class="col-md-3">

                    <select class="form-select"
                            name="status">

                        <option value="">Status</option>

                        <option value="Delivered">Delivered</option>

                        <option value="Delayed">Delayed</option>

                        <option value="In Transit">In Transit</option>

                        <option value="Preparing">Preparing</option>

                    </select>

                </div>

                <div class="col-md-3">

                    <button class="btn btn-primary w-100">
                        Search Shipments
                    </button>

                </div>

            </div>

        </form>

    </div>

    <div class="table-responsive text-nowrap">

        <table class="table">

            <thead>
                <tr>
                    <th>Tracking Code</th>
                    <th>Sender City</th>
                    <th>Receiver City</th>
                    <th>Status</th>
                    <th>Price</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody class="table-border-bottom-0">

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            <strong>@item.TrackingCode</strong>
                        </td>

                        <td>
                            @item.SenderCity
                        </td>

                        <td>
                            @item.ReceiverCity
                        </td>

                        <td>

                            @if (item.Status == "Delivered")
                            {
                                <span class="badge bg-label-success me-1">
                                    Delivered
                                </span>
                            }

                            else if (item.Status == "Delayed")
                            {
                                <span class="badge bg-label-danger me-1">
                                    Delayed
                                </span>
                            }

                            else if (item.Status == "In Transit")
                            {
                                <span class="badge bg-label-warning me-1">
                                    In Transit
                                </span>
                            }

                            else
                            {
                                <span class="badge bg-label-primary me-1">
                                    Preparing
                                </span>
                            }

                        </td>

                        <td>
                            ₺ @item.ShippingPrice
                        </td>

                        <td>
                            @item.ShipmentDate.ToShortDateString()
                        </td>

                        <td>

                            <a href="/Shipment/EditShipment/@item.ShipmentId"
                               class="btn btn-sm btn-outline-primary">

                                Edit

                            </a>
                            <a href="/Shipment/Detail/@item.ShipmentId"
                               class="btn btn-outline-info btn-sm">
                                View
                            </a>

                            <a href="/Shipment/DeleteShipment/@item.ShipmentId"
                               class="btn btn-sm btn-outline-danger">

                                Delete

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

        <div class="card-footer">

            <nav>

                <ul class="pagination justify-content-end">

                    <li class="page-item disabled">
                        <a class="page-link" href="#">
                            Previous
                        </a>
                    </li>

                    <li class="page-item active">
                        <a class="page-link" href="#">
                            1
                        </a>
                    </li>

                    <div class="card-footer d-flex justify-content-end mt-3">

                        <nav>

                            <ul class="pagination">

                                <li class="page-item">
                                    <a class="page-link" href="/Shipment/Index?page=1">
                                        1
                                    </a>
                                </li>

                                <li class="page-item">
                                    <a class="page-link" href="/Shipment/Index?page=2">
                                        2
                                    </a>
                                </li>

                                <li class="page-item">
                                    <a class="page-link" href="/Shipment/Index?page=3">
                                        3
                                    </a>
                                </li>

                            </ul>

                        </nav>

                    </div>

                </ul>

            </nav>

        </div>

    </div>

</div>